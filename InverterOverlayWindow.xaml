<Window x:Class="ScreenInverter.InverterOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screen Inverter"
        Width="400" Height="300"
        MinWidth="100" MinHeight="100"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize">

    <Border x:Name="MainBorder"
            BorderBrush="#40FFFFFF"
            BorderThickness="2"
            Background="Transparent">
        <Grid>
            <!-- 屏幕捕获内容 -->
            <Image x:Name="CapturedImage"
                   Stretch="Fill"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>

            <!-- 控制按钮 (鼠标悬停时显示) -->
            <Border x:Name="ControlBar"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Stretch"
                    Background="#80000000"
                    Height="30"
                    Visibility="Visible">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 拖动区域提示 -->
                    <TextBlock Grid.Column="0"
                               Text="拖动调整位置 | 拖动边缘/角落调整大小"
                               VerticalAlignment="Center"
                               Foreground="White"
                               Margin="10,0,0,0"
                               FontSize="12"/>

                    <!-- 反转模式切换 -->
                    <Button Grid.Column="1"
                            x:Name="ModeButton"
                            Content="模式：全反转"
                            Click="ModeButton_Click"
                            Foreground="White"
                            Background="#40FFFFFF"
                            BorderThickness="0"
                            Margin="5,2,5,2"
                            FontSize="11"/>

                    <!-- 关闭按钮 -->
                    <Button Grid.Column="2"
                            Content="✕"
                            Click="CloseButton_Click"
                            Foreground="White"
                            Background="#C03030"
                            BorderThickness="0"
                            Margin="5,2,5,2"
                            Width="24"
                            FontSize="14"/>
                </Grid>
            </Border>

            <!-- 调整大小手柄 - 四个角落和四个边缘 -->
            <!-- 左上角 -->
            <Thumb Width="40" Height="40" HorizontalAlignment="Left" VerticalAlignment="Top"
                   Margin="-15,-15,0,0"
                   Cursor="SizeNWSE" DragDelta="OnTopLeftCornerResize">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>

            <!-- 右上角 - 留给关闭按钮，不设手柄 -->

            <!-- 左下角 -->
            <Thumb Width="40" Height="40" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                   Margin="-15,0,0,-15"
                   Cursor="SizeNESW" DragDelta="OnBottomLeftCornerResize">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>

            <!-- 右下角 -->
            <Thumb Width="40" Height="40" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Margin="0,0,-15,-15"
                   Cursor="SizeNWSE" DragDelta="OnBottomRightCornerResize">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>

            <!-- 上边缘 -->
            <Thumb Height="30" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                   Margin="0,-15,0,0"
                   Cursor="SizeNS" DragDelta="OnTopEdgeResize">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>

            <!-- 下边缘 -->
            <Thumb Height="30" HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                   Margin="0,0,0,-15"
                   Cursor="SizeNS" DragDelta="OnBottomEdgeResize">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>

            <!-- 左边缘 -->
            <Thumb Width="30" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                   Margin="-15,0,0,0"
                   Cursor="SizeWE" DragDelta="OnLeftEdgeResize">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>

            <!-- 右边缘 - 避开控制栏区域，只在下半部分 -->
            <Thumb Width="30" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                   Margin="0,30,0,-15"
                   Cursor="SizeWE" DragDelta="OnRightEdgeResize">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Grid>
    </Border>
</Window>